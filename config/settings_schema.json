[
  {
    "name": "theme_info",
    "theme_name": "ThePlanetSoft",
    "theme_version": "1.0.0",
    "theme_author": "Dvij Infotech LLP",
    "theme_documentation_url": "https://theplanetsoft.com/",
    "theme_support_url": "https://theplanetsoft.com/"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:favicon.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:favicon.settings.favicon.label",
        "info": "t:favicon.settings.favicon.info"
      }
    ] 
  },
  {
    "name": "t:social_media.name",
    "settings": [
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "t:social_media.settings.social_facebook_link.label",
        "placeholder": "t:social_media.settings.social_facebook_link.info"
      },

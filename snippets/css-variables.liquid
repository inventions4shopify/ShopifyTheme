{% style %}
  {% # Loads all font variantions with display: swap %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    --font-primary--family: {{ settings.type_primary_font.family }}, {{ settings.type_primary_font.fallback_families }};
    --font-primary--style: {{ settings.type_primary_font.style }};
    --font-primary--weight: {{ settings.type_primary_font.weight }};

    /* Page width */
    --page-width: {{ settings.page_width_max }}px;

    /* Section spacing - Desktop, Tablet, Mobile */
    --section-spacing-desktop: {{ settings.section_spacing_desktop }}px;
    --section-spacing-tablet: {{ settings.section_spacing_desktop | plus: settings.section_spacing_mobile | divided_by: 2 }}px;
    --section-spacing-mobile: {{ settings.section_spacing_mobile }}px;
    --section-spacing: var(--section-spacing-mobile);

    /* Grid spacing - Desktop, Tablet, Mobile */
    --grid-spacing-desktop: {{ settings.grid_spacing_desktop }}px;
    --grid-spacing-tablet: {{ settings.grid_spacing_desktop | plus: settings.grid_spacing_mobile | divided_by: 2 }}px;
    --grid-spacing-mobile: {{ settings.grid_spacing_mobile }}px;
    --grid-spacing: var(--grid-spacing-mobile);

    /* General colors */
    --color-background: {{ settings.background_color }};
    --color-heading: {{ settings.heading_color }};
    --color-subheading: {{ settings.subheading_color }};
    --color-body-text: {{ settings.body_text_color }};
    --color-success: {{ settings.success_color }};
    --color-warning: {{ settings.warning_color }};
    --color-error: {{ settings.error_color }};
    --color-border: {{ settings.border_color }};
    --color-border-opacity: {{ settings.border_opacity | default: 1 }};

    /* Header colors */
    --color-header-background: {{ settings.header_background_color }};
    --color-header-text: {{ settings.header_text_color }};
    --color-header-hover-text: {{ settings.header_hover_text_color }};

    /* Footer colors */
    --color-footer-background: {{ settings.footer_background_color }};
    --color-footer-text: {{ settings.footer_text_color }};
    --color-footer-hover-text: {{ settings.footer_hover_text_color }};

    /* Primary button colors */
    --color-button-primary-text: {{ settings.primary_button_text_color }};
    --color-button-primary-background: {{ settings.primary_button_background_color }};
    --color-button-primary-outline: {{ settings.primary_button_outline_color }};

    /* Secondary button colors */
    --color-button-secondary-text: {{ settings.secondary_button_text_color }};
    --color-button-secondary-background: {{ settings.secondary_button_background_color }};
    --color-button-secondary-outline: {{ settings.secondary_button_outline_color }};

    /* Product card colors */
    --color-product-card-background: {{ settings.product_card_background_color }};
    --color-product-card-text: {{ settings.product_card_text_color }};
    --color-product-star-rating: {{ settings.product_star_rating_color }};

    /* Product badge colors */
    --color-sale-badge-background: {{ settings.sale_badge_background_color }};
    --color-sale-badge-text: {{ settings.sale_badge_text_color }};
    --color-sold-badge-background: {{ settings.sold_badge_background_color }};
    --color-sold-badge-text: {{ settings.sold_badge_text_color }};
    --color-custom-badge-background: {{ settings.custom_badge_background_color }};
    --color-custom-badge-text: {{ settings.custom_badge_text_color }};
  }

  /* Tablet breakpoint - min-width 769px */
  @media screen and (min-width: 769px) {
    :root {
      --section-spacing: var(--section-spacing-tablet);
      --grid-spacing: var(--grid-spacing-tablet);
    }
  }

  /* Desktop breakpoint - min-width 1025px */
  @media screen and (min-width: 1025px) {
    :root {
      --section-spacing: var(--section-spacing-desktop);
      --grid-spacing: var(--grid-spacing-desktop);
    }
  }
{% endstyle %}

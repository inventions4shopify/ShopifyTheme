    <li class="social__item">
      <a href="{{ settings.social_facebook_link }}" target="_blank" class="social_link">
        <span class="svg-wrapper">
          {{ 'social_media.settings.social_facebook_link.label' | t }}
        </span>
        <span class="hidden">{{ 'social_media.settings.social_facebook_link.info' | t }}</span>
